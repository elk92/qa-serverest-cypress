{
  "name": "qa-serverest-cypress",
  "version": "1.0.0",
  "description": "Automation testing project using Cypress and JavaScript for E2E and API testing against ServeRest.",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:frontend": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:all": "cypress run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "quality": "npm run lint && npm run test:all"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cypress",
    "automation",
    "testing",
    "qa",
    "e2e",
    "api",
    "serverest"
  ],
  "author": "Elcio Santos Filho",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "cypress": "^15.18.1",
    "eslint": "^10.7.0",
    "eslint-plugin-cypress": "^6.4.3",
    "globals": "^17.7.0"
  }
}